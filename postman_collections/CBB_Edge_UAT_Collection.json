                  "raw": "{{baseUrl}}/api/fantasy/roster"
                },
                "description": "Get current roster with player counts by slot, eligibility, and metadata"
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status code is 200', () => {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "pm.test('Returns roster structure', () => {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json).to.have.property('slots');",
                      "    pm.expect(json).to.have.property('players');",
                      "    pm.expect(json).to.have.property('metadata');",
                      "});",
                      "// Save first player ID for later tests",
                      "try {",
                      "    const json = pm.response.json();",
                      "    if (json.players && json.players.length > 0) {",
                      "        pm.variables.set('testPlayerId', json.players[0].player_id);",
                      "        console.log('Saved testPlayerId:', json.players[0].player_id);",
                      "    }",
                      "} catch(e) { console.log('Could not save player ID'); }"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Roster Move (Add/Drop)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"moves\": [\n    {\n      \"type\": \"add\",\n      \"player_id\": \"{{testPlayerId}}\",\n      \"target_slot\": \"BN\"\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/fantasy/roster/move"
                },
                "description": "Execute roster moves (add/drop/swap). Validation only - use Yahoo app to confirm."
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status code is 200 or 422 (validation)', () => {",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 422]);",
                      "});"
                    ]
                  }
                }
              ]
            },
