{
  "info": {
    "name": "CBB Edge - MLB Platform UAT Collection",
    "description": "Comprehensive API testing collection for manual UAT of the MLB Fantasy + Betting platform. Organized by functional area with pre-configured authentication and test data.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0",
    "_postman_id": "cbb-edge-uat-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://fantasy-app-production-5079.up.railway.app",
      "type": "string",
      "description": "Production Railway URL - update with your actual deployment"
    },
    {
      "key": "apiKey",
      "value": "{{API_KEY_USER1}}",
      "type": "secret",
      "description": "API authentication key from .env"
    },
    {
      "key": "leagueId",
      "value": "72586",
      "type": "string",
      "description": "Yahoo Fantasy League ID"
    },
    {
      "key": "teamKey",
      "value": "{{teamKey}}",
      "type": "string",
      "description": "Yahoo team key (e.g., 469.l.72586.t.1)"
    },
    {
      "key": "todayDate",
      "value": "{{$timestamp}}",
      "type": "string",
      "description": "Today's date for dynamic queries"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "value",
        "value": "{{apiKey}}",
        "type": "string"
      },
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set today's date in ET timezone",
          "const today = new Date();",
          "const etOffset = today.getTimezoneOffset() * 60000;",
          "const etDate = new Date(today.getTime() - etOffset);",
          "pm.variables.set('todayDate', etDate.toISOString().split('T')[0]);",
          "",
          "// Log environment info",
          "console.log('Testing against:', pm.variables.get('baseUrl'));",
          "console.log('Date (ET):', pm.variables.get('todayDate'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0_Health_Check",
      "item": [
        {
          "name": "Root Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/"
            },
            "description": "Root endpoint - should return API name and version"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns API info', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('name');",
                  "    pm.expect(json).to.have.property('version');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health"
            },
            "description": "Health check endpoint - verifies API is running"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns healthy status', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status', 'healthy');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1_Fantasy_Baseball",
      "item": [
        {
          "name": "Draft Board",
          "item": [
            {
              "name": "Get Full Draft Board",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/fantasy/draft-board?limit=200",
                  "query": [
                    {
                      "key": "position",
                      "value": "OF",
                      "disabled": true
                    },
                    {
                      "key": "player_type",
                      "value": "batter",
                      "disabled": true
                    },
                    {
                      "key": "tier_max",
                      "value": "3",
                      "disabled": true
                    },
                    {
                      "key": "limit",
                      "value": "200"
                    }
                  ]
                },
                "description": "Get ranked fantasy draft board with Steamer/ZiPS projections"
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status code is 200', () => {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "pm.test('Returns players array', () => {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json).to.have.property('players');",
                      "    pm.expect(json.players).to.be.an('array');",
                      "});",
                      "pm.test('Player has required fields', () => {",
                      "    const json = pm.response.json();",
                      "    if (json.players.length > 0) {",
                      "        const player = json.players[0];",
                      "        pm.expect(player).to.have.property('player_id');",
                      "        pm.expect(player).to.have.property('name');",
                      "        pm.expect(player).to.have.property('position');",
                      "        pm.expect(player).to.have.property('tier');",
                      "    }",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get Player Detail",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/fantasy/player/{{playerId}}",
                  "variable": [
                    {
                      "key": "playerId",
                      "value": "1",
                      "description": "Yahoo Player ID or BDL ID"
                    }
                  ]
                },
                "description": "Get detailed info for a single player including projections"
              },
              "response": []
            }
          ]
        },
        {
