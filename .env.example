# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cbb_edge

# API Keys (REQUIRED)
THE_ODDS_API_KEY=your_odds_api_key_here
KENPOM_API_KEY=your_kenpom_api_key_here

# Authentication (generate random 32+ char strings)
API_KEY_USER1=change_this_to_random_secure_string_min_32_chars
API_KEY_USER2=optional_second_user_key

# Optional: Paid tier access
BARTTORVIK_USERNAME=
BARTTORVIK_PASSWORD=
EVANMIYA_API_KEY=

# Optional: SMS Alerts (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Optional: Email Alerts (SendGrid)
SENDGRID_API_KEY=
ALERT_EMAIL=sfgray26@gmail.com

# Optional: Discord Notifications
# Bot must be invited to your server with Send Messages permission.
# Channel ID is hardcoded to 1477436117426110615; override here if needed.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=1477436117426110615

# App Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
NIGHTLY_CRON_HOUR=3
NIGHTLY_CRON_TIMEZONE=America/New_York

# Model Parameters (adjust after validation)
BASE_SD=11.0
WEIGHT_KENPOM=0.342
WEIGHT_BARTTORVIK=0.333
WEIGHT_EVANMIYA=0.325
HOME_ADVANTAGE=3.09

# Betting Parameters
MAX_KELLY_FRACTION=0.20
FRACTIONAL_KELLY_DIVISOR=2
MAX_BANKROLL_PCT_PER_BET=1.5
STARTING_BANKROLL=1000

# Minimum edge floor for a BET verdict (D4 block in betting_model.py).
# Edges at or below this threshold are logged as CONSIDER, never placed.
# Default 2.5%. Raise toward 3-5% once market blend is confirmed live.
# Raising from 2.5% to 3.0% reduces BET-tier volume approx 10-15%.
MIN_BET_EDGE=2.5

# Portfolio daily exposure cap — total paper-trade dollars as % of bankroll.
# Prevents independent Kelly bets from stacking into runaway exposure on
# busy college basketball slates (e.g. Saturday with 60+ games).
MAX_DAILY_EXPOSURE_PCT=5.0

# Ratings
SEASON_YEAR=2026
# Override data source URLs if sites restructure (optional)
# BARTTORVIK_URL=https://barttorvik.com/2026_team_results.csv
# EVANMIYA_URL=https://evanmiya.com/

# Recalibration — sd_multiplier is persisted to model_parameters table;
# env vars below are the initial/fallback values only.
SD_MULTIPLIER=0.85

# Margin SE tuning — CI widens under degraded data conditions
# 1.50 gives 1.96*1.50 = 2.94pt CI width → ~9.3% haircut at adj_sd=11
BASE_MARGIN_SE=1.50
EVANMIYA_DOWN_SE_ADDEND=0.30
NO_SHARP_BOOKS_SE_ADDEND=0.30
MISSING_SOURCE_SE_PTS=0.15
MAX_MARGIN_SE=2.50

# Safety Limits
MAX_DRAWDOWN_PCT=15.0
CLV_PAUSE_THRESHOLD=-0.005
CALIBRATION_ERROR_THRESHOLD=0.07
MIN_BETS_FOR_RECALIBRATION=30

# Scheduler tuning
# Ratings pre-warm job hour (local timezone above); default 8 AM
RATINGS_PREWARM_HOUR=8
# Odds monitor active window — only polls during [START, END) local time
# Prevents quota burn when no games are scheduled (overnight, early AM)
ODDS_MONITOR_START_HOUR=12
ODDS_MONITOR_END_HOUR=23
# Stop polling odds monitor when fewer than N API requests remain
ODDS_API_QUOTA_RESERVE=10

# ==========================================
# A-26: Seed-Spread Kelly Scalars
# ==========================================

# BallDontLie API (required for tournament seed data)
BALLDONTLIE_API_KEY=your_api_key_here

# Seed-spread scalar overrides (optional)
SEED5_FAV6PLUS_SCALAR=0.75    # #5 seed fav 6+ pts
SEED2_FAV17PLUS_SCALAR=0.75   # #2 seed fav 17+ pts
SEED8_FAV3MINUS_SCALAR=0.80   # #8 seed fav <=3 pts

# ==========================================
# O-9: Tiered Escalation Coordinator
# ==========================================
ESCALATION_UNITS_THRESHOLD=1.5  # Units threshold for Kimi escalation flag (O-9)

# ==========================================
# Fantasy Baseball — Yahoo API
# ==========================================
# Get credentials at: https://developer.yahoo.com/apps/
# Callback URI must be set to "oob" for CLI auth flow
YAHOO_CLIENT_ID=your_yahoo_consumer_key_here
YAHOO_CLIENT_SECRET=your_yahoo_consumer_secret_here
YAHOO_LEAGUE_ID=72586
# Set automatically by auth flow (python -m backend.fantasy_baseball.yahoo_client --auth)
YAHOO_REFRESH_TOKEN=
YAHOO_ACCESS_TOKEN=

# Fantasy Baseball — Local Qwen (OpenClaw/Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:latest
